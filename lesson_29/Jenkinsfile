pipeline {
    agent any

    options {
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {
        stage('Checkout') {
            steps {
                echo '📥 Завантажуємо код з репозиторію...'
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                echo '📦 Встановлюємо залежності...'
                bat '''
                    "C:\\Users\\YuriiDavydiak\\AppData\\Local\\Python\\pythoncore-3.14-64\\python.exe" -m pip install --upgrade pip
                    "C:\\Users\\YuriiDavydiak\\AppData\\Local\\Python\\pythoncore-3.14-64\\python.exe" -m pip install -r requirements.txt
                '''
            }
        }

        stage('Run Tests') {
            steps {
                echo '🧪 Запускаємо автотести...'
                bat '''
                    if not exist test-results mkdir test-results
                    "C:\\Users\\YuriiDavydiak\\AppData\\Local\\Python\\pythoncore-3.14-64\\python.exe" -m pytest tests/ --html=test-results/report.html --self-contained-html --junitxml=test-results/junit.xml -v --tb=short
                '''
            }
        }

        stage('Publish Results') {
            steps {
                echo '📊 Публікуємо результати тестування...'
                junit 'test-results/junit.xml'
                publishHTML([
                    reportDir: 'test-results',
                    reportFiles: 'report.html',
                    reportName: 'pytest Report',
                    alwaysLinkToLastBuild: true,
                    keepAll: true
                ])
            }
        }
    }

    post {
        always {
            echo '🧹 Очищуємо після завершення...'
            archiveArtifacts artifacts: 'test-results/**', allowEmptyArchive: true
        }

        success {
            echo '✅ Тести пройшли успішно!'
            emailext(
                subject: '✅ Jenkins Pipeline SUCCESS: ${JOB_NAME} - Build #${BUILD_NUMBER}',
                body: '''
                    <h2>✅ Тести пройшли успішно!</h2>
                    <table border="1" cellpadding="5">
                        <tr>
                            <td><b>Проект:</b></td>
                            <td>${JOB_NAME}</td>
                        </tr>
                        <tr>
                            <td><b>Build #:</b></td>
                            <td>${BUILD_NUMBER}</td>
                        </tr>
                        <tr>
                            <td><b>Branch:</b></td>
                            <td>${GIT_BRANCH}</td>
                        </tr>
                        <tr>
                            <td><b>Duration:</b></td>
                            <td>${BUILD_DURATION}</td>
                        </tr>
                        <tr>
                            <td><b>Status:</b></td>
                            <td style="color: green;"><b>SUCCESS</b></td>
                        </tr>
                    </table>

                    <h3>Деталі:</h3>
                    <p><a href="${BUILD_URL}pytest_Report/">Переглянути HTML звіт</a></p>
                    <p><a href="${BUILD_URL}console">Переглянути консоль</a></p>
                ''',
                to: '${DEFAULT_RECIPIENTS}',
                mimeType: 'text/html',
                recipientProviders: [developers(), requestor()]
            )
        }

        failure {
            echo '❌ Тести не пройшли!'
            emailext(
                subject: '❌ Jenkins Pipeline FAILED: ${JOB_NAME} - Build #${BUILD_NUMBER}',
                body: '''
                    <h2 style="color: red;">❌ Тести не пройшли!</h2>
                    <table border="1" cellpadding="5">
                        <tr>
                            <td><b>Проект:</b></td>
                            <td>${JOB_NAME}</td>
                        </tr>
                        <tr>
                            <td><b>Build #:</b></td>
                            <td>${BUILD_NUMBER}</td>
                        </tr>
                        <tr>
                            <td><b>Branch:</b></td>
                            <td>${GIT_BRANCH}</td>
                        </tr>
                        <tr>
                            <td><b>Duration:</b></td>
                            <td>${BUILD_DURATION}</td>
                        </tr>
                        <tr>
                            <td><b>Status:</b></td>
                            <td style="color: red;"><b>FAILED</b></td>
                        </tr>
                    </table>

                    <h3>Деталі:</h3>
                    <p><a href="${BUILD_URL}pytest_Report/">Переглянути звіт</a></p>
                    <p><a href="${BUILD_URL}console">Переглянути консоль</a></p>
                ''',
                to: '${DEFAULT_RECIPIENTS}',
                mimeType: 'text/html',
                recipientProviders: [developers(), requestor()]
            )
        }

        unstable {
            echo '⚠️ Pipeline нестабільний'
            emailext(
                subject: '⚠️ Jenkins Pipeline UNSTABLE: ${JOB_NAME} - Build #${BUILD_NUMBER}',
                body: 'Pipeline завершив роботу зі статусом UNSTABLE.',
                to: '${DEFAULT_RECIPIENTS}',
                mimeType: 'text/html'
            )
        }
    }
}
