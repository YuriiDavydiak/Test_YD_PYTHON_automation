pipeline {
    agent any

    options {
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
    }

    stages {
        stage('Checkout') {
            steps {
                echo '📥 Завантажуємо код з репозиторію...'
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                echo '📦 Встановлюємо залежності...'
                bat '''
                    cd lesson_29
                    "C:\\Users\\YuriiDavydiak\\AppData\\Local\\Python\\pythoncore-3.14-64\\python.exe" -m pip install --upgrade pip
                    "C:\\Users\\YuriiDavydiak\\AppData\\Local\\Python\\pythoncore-3.14-64\\python.exe" -m pip install -r requirements.txt
                '''
            }
        }

        stage('Install Playwright Browsers') {
            steps {
                echo '🌐 Встановлюємо браузери Playwright...'
                bat '''
                    cd lesson_29
                    "C:\\Users\\YuriiDavydiak\\AppData\\Local\\Python\\pythoncore-3.14-64\\python.exe" -m playwright install
                '''
            }
        }

        stage('Run Tests') {
            steps {
                echo '🧪 Запускаємо автотести...'
                bat '''
                    cd lesson_29
                    if not exist test-results mkdir test-results
                    "C:\\Users\\YuriiDavydiak\\AppData\\Local\\Python\\pythoncore-3.14-64\\python.exe" -m pytest tests/ --html=test-results/report.html --self-contained-html --junitxml=test-results/junit.xml -v --tb=short
                '''
            }
        }

        stage('Publish Results') {
            steps {
                echo '📊 Публікуємо результати тестування...'
                junit 'lesson_29/test-results/junit.xml'
                archiveArtifacts artifacts: 'lesson_29/test-results/**', allowEmptyArchive: true
            }
        }
    }

    post {
        always {
            echo '🧹 Очищуємо після завершення...'
            archiveArtifacts artifacts: 'lesson_29/test-results/**', allowEmptyArchive: true
        }

        success {
            echo '✅ Тести пройшли успішно!'
            emailext(
                subject: "✅ Jenkins Build Success - ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
Build Success!

Job: ${env.JOB_NAME}
Build Number: ${env.BUILD_NUMBER}
Build URL: ${env.BUILD_URL}

Test Results: ${env.BUILD_URL}testReport/

All tests PASSED ✅
""",
                to: "hilelul@mail.com",
                mimeType: 'text/plain'
            )
        }

        failure {
            echo '❌ Тести не пройшли!'
            emailext(
                subject: "❌ Jenkins Build FAILED - ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
Build FAILED!

Job: ${env.JOB_NAME}
Build Number: ${env.BUILD_NUMBER}
Build URL: ${env.BUILD_URL}

Test Results: ${env.BUILD_URL}testReport/

Please check the logs at: ${env.BUILD_URL}console
""",
                to: "hilelul@mail.com",
                mimeType: 'text/plain'
            )
        }
    }
}
